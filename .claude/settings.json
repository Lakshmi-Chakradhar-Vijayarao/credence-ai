{
  "mcpServers": {
    "credence": {
      "command": "credence-server",
      "env": {
        "CREDENCE_DB": "epistemic_registry.db"
      }
    }
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -m credence.observer"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|Bash|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -m credence.hooks"
          }
        ]
      }
    ]
  }
}
